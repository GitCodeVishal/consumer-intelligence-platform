NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=consumer_platform

# Segmentation thresholds (optional — defaults shown)
SEG_HIGH_VALUE_THRESHOLD=500
SEG_DORMANT_DAYS=60
SEG_CROSS_BRAND_ACTIVE_DAYS=90
SEG_CROSS_BRAND_MIN_BRANDS=2
SEG_LIFECYCLE_WINDOW_DAYS=60

# Propensity scoring weights and windows (optional — defaults shown)
PROP_WEIGHT_RECENCY=0.4
PROP_WEIGHT_FREQUENCY=0.3
PROP_WEIGHT_ENGAGEMENT=0.3
PROP_FREQUENCY_WINDOW_DAYS=90
PROP_ENGAGEMENT_WINDOW_DAYS=30
